// ============================================
// PULSECHAIN ANALYTICS - DATABASE SCHEMA
// PostgreSQL + Prisma ORM
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  avatar        String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  portfolios    Portfolio[]
  alerts        PriceAlert[]
  watchlist     WatchlistCoin[]
  affiliate     Affiliate?
  sessions      Session[]
  apiKeys       ApiKey[]
  blogPosts     BlogPost[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  key       String    @unique
  name      String
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([key])
}

// ============================================
// PORTFOLIO & HOLDINGS
// ============================================

model Portfolio {
  id         String             @id @default(cuid())
  userId     String
  name       String
  totalValue Float              @default(0)
  pnl        Float              @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings   PortfolioHolding[]
  
  @@index([userId])
}

model PortfolioHolding {
  id          String    @id @default(cuid())
  portfolioId String
  coinId      String
  amount      Float
  buyPrice    Float
  createdAt   DateTime  @default(now())
  
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  @@index([portfolioId])
  @@index([coinId])
}

// ============================================
// PRICE ALERTS & NOTIFICATIONS
// ============================================

model PriceAlert {
  id               String        @id @default(cuid())
  userId           String
  coinId           String
  targetPrice      Float
  condition        AlertCondition
  notificationType NotificationType
  isActive         Boolean       @default(true)
  triggeredAt      DateTime?
  createdAt        DateTime      @default(now())
  
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([coinId])
  @@index([isActive])
}

model WatchlistCoin {
  id      String   @id @default(cuid())
  userId  String
  coinId  String
  addedAt DateTime @default(now())
  
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, coinId])
  @@index([userId])
}

// ============================================
// AFFILIATE & REFERRALS
// ============================================

model Affiliate {
  id            String       @id @default(cuid())
  userId        String       @unique
  referralCode  String       @unique
  totalEarnings Float        @default(0)
  tier          AffiliateTier @default(BRONZE)
  createdAt     DateTime     @default(now())
  
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals     Referral[]
  payouts       Payout[]
  
  @@index([referralCode])
}

model Referral {
  id            String         @id @default(cuid())
  affiliateId   String
  referredEmail String?
  commission    Float          @default(0)
  status        ReferralStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  
  affiliate     Affiliate      @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  
  @@index([affiliateId])
  @@index([status])
}

model Payout {
  id          String       @id @default(cuid())
  affiliateId String
  amount      Float
  status      PayoutStatus @default(PENDING)
  method      String       @default("USDC")
  address     String
  paidAt      DateTime?
  txHash      String?
  createdAt   DateTime     @default(now())
  
  affiliate   Affiliate    @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  
  @@index([affiliateId])
  @@index([status])
}

// ============================================
// BLOG & CONTENT
// ============================================

model BlogPost {
  id             String       @id @default(cuid())
  title          String
  slug           String       @unique
  content        String
  excerpt        String?
  featuredImage  String?
  category       BlogCategory
    tags           String   @default("")
  seoTitle       String?
  seoDescription String?
  isPublished    Boolean      @default(false)
  publishedAt    DateTime?
  authorId       String
  viewCount      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  author         User         @relation(fields: [authorId], references: [id])
  
  @@index([slug])
  @@index([isPublished])
  @@index([category])
  @@index([publishedAt])
  @@index([createdAt])
}

// ============================================
// CACHE & MARKET DATA
// ============================================

model CoinCache {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model MarketMetrics {
  id        String   @id @default("global")
  data      Json
  updatedAt DateTime @updatedAt
}

// ============================================
// ENUMS
// ============================================

enum Role {
  USER
  ADMIN
  AFFILIATE_MANAGER
}

enum AlertCondition {
  ABOVE
  BELOW
  PERCENTAGE_CHANGE
  VOLUME_SPIKE
  WHALE_MOVEMENT
}

enum NotificationType {
  EMAIL
  PUSH
  SMS
}

enum AffiliateTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum ReferralStatus {
  PENDING
  ACTIVE
  CHURNED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BlogCategory {
  MARKET_ANALYSIS
  TECHNICAL_ANALYSIS
  DEFI
  NFT
  TUTORIAL
  NEWS
  PREDICTION
}
