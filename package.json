{
  "name": "pulsechain-analytics",
  "version": "1.0.0",
  "description": "AI-Powered Cryptocurrency Market Intelligence Platform",
  "private": true,
  "license": "MIT",
  "author": "PulseChain Analytics",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "blog:generate": "tsx scripts/generate-blog.ts",
    "sitemap:update": "tsx scripts/update-sitemap.ts",
    "market:sync": "tsx scripts/sync-market-data.ts",
    "market:sync:watch": "tsx scripts/sync-market-data.ts --watch",
    "images:optimize": "tsx scripts/optimize-images.ts",
    "seed": "tsx scripts/seed-database.ts",
    "deploy": "bash scripts/deploy.sh",
    "deploy:prod": "bash scripts/deploy.sh --prod --seed",
    "postinstall": "prisma generate",
    "clean": "rm -rf .next node_modules",
    "reset": "npm run clean && npm install"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "critters": "^0.0.23",
    "jose": "^5.1.3",
    "lucide-react": "^0.300.0",
    "next": "14.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.13",
    "prisma": "^5.7.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
